# Database (use Neon, Supabase, or Vercel Postgres for serverless)
DATABASE_URL="postgresql://dip_user:dip_password@localhost:5432/demand_intel?schema=public"

# Auth
JWT_SECRET="change-me-to-a-random-64-char-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ML Services (optional — omit for Vercel-only deployment)
# FORECAST_SERVICE_URL=http://localhost:8001
# OPTIMIZER_SERVICE_URL=http://localhost:8002
# ANALYTICS_SERVICE_URL=http://localhost:8003
