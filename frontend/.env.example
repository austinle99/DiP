# API Configuration
# For local dev:      http://localhost:3001/api
# For Vercel:         /api  (same-origin, handled by rewrites in vercel.json)
VITE_API_BASE_URL=http://localhost:3001/api

# Feature Flags
VITE_ENABLE_MOCKS=true

# Auth (when backend is ready)
# VITE_AUTH_DOMAIN=
# VITE_AUTH_CLIENT_ID=
